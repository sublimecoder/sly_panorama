            ]}
            title="Set your Tryst or booking profile URL"
          >
            <.icon name="hero-calendar-mini" class="size-5 shrink-0 text-sly-accent/70" /> Booking profile (TBD)
          </span>
          <span
            class={[
              "inline-flex min-w-[10rem] cursor-not-allowed items-center justify-center gap-2 rounded-lg border border-dashed border-white/25 px-4 py-2.5 text-sm font-semibold",
              "bg-white/5 text-sly-ink-dim"
            ]}
            title="Set your text / fan message URL"
          >
            <.icon name="hero-chat-bubble-left-right-mini" class="size-5 shrink-0 text-sly-accent/70" /> Fan messages (TBD)
          </span>
        </div>
      </div>

      <div class="flex w-full max-w-2xl flex-col gap-3">
        <p class="text-xs font-semibold uppercase tracking-wider text-sly-ink-dim">Social</p>
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:justify-center">
          <span
            class={[
              "inline-flex min-w-[10rem] cursor-not-allowed items-center justify-center gap-2 rounded-lg border border-dashed border-white/25 px-4 py-2.5 text-sm font-semibold",
              "bg-white/5 text-sly-ink-dim"
            ]}
            title="Set your Instagram URL"
          >
            <.icon name="hero-camera-mini" class="size-5 shrink-0 opacity-70" /> Instagram (TBD)
          </span>
          <span
            class={[
              "inline-flex min-w-[10rem] cursor-not-allowed items-center justify-center gap-2 rounded-lg border border-dashed border-white/25 px-4 py-2.5 text-sm font-semibold",
