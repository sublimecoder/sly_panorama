<div
  id="gallery-page"
  class="container gallery mx-auto px-4 py-8 sm:px-6"
  data-gallery-images={@gallery_images_json}
>
  <%!-- Gallery Intro --%>
  <section class="mx-auto mb-10 max-w-3xl space-y-4 text-center text-sly-ink">
    <h2 class="text-xl font-semibold text-sly-ink">Gallery</h2>
    <p class="text-sly-ink/90">
      A curated collection of Sly Panorama’s most captivating moments, both on and off camera. From high-quality
      visuals to exclusive behind-the-scenes and candid shots that reveal the energy behind every scene.
    </p>
    <p class="text-sly-ink/90">
      No explicit content is shown here. Full access lives behind a subscription for those who want more.
    </p>
  </section>

  <%!-- Gallery Grid --%>
  <div id="gallery-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
    <%= if @images == [] do %>
      <div class="col-span-full rounded-2xl border border-dashed border-white/20 bg-sly-surface/40 px-6 py-16 text-center text-sly-ink-dim">
        No gallery images yet.
      </div>
    <% else %>
      <%= for {img, index} <- Enum.with_index(@images) do %>
        <% {file, alt} = img %>
        <div
          data-gallery-item
          data-gallery-index={index}
          class="group cursor-pointer overflow-hidden rounded-2xl border border-white/10 bg-sly-surface/80 shadow-lg transition duration-300 hover:-translate-y-0.5 hover:border-white/20 hover:shadow-xl"
        >
          <figure class="m-0">
            <img
              src={"/images/gallery/#{file}"}
              alt={alt}
              class="h-64 w-full object-cover transition duration-500 group-hover:opacity-95"
            />
          </figure>
        </div>
      <% end %>
    <% end %>
  </div>

  <%!-- Lightbox Modal --%>
  <div
    id="lightbox"
    class="fixed inset-0 z-50 hidden bg-black/70 p-4 backdrop-blur-sm"
    role="dialog"
    aria-modal="true"
    aria-label="Gallery image preview"
  >
    <div class="flex h-full w-full items-center justify-center">
    <div class="lightbox-content relative w-full max-w-5xl rounded-2xl border border-white/10 bg-sly-surface shadow-2xl">
      <button
        type="button"
        id="close-lightbox"
        class="absolute right-3 top-3 z-10 flex size-9 items-center justify-center rounded-full border border-white/20 bg-sly-elevated text-sly-ink transition hover:bg-sly-accent hover:text-white"
        aria-label="Close"
      >
        <.icon name="hero-x-mark-mini" class="size-5 shrink-0" />
      </button>

      <figure class="m-0">
        <img id="lightbox-img" src="" alt="" class="max-h-[80vh] w-full rounded-t-2xl object-contain py-4" />
      </figure>

      <div class="flex items-center justify-between gap-4 border-t border-white/10 px-4 py-4 sm:px-6">
        <button
          type="button"
          id="prev-btn"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-sly-elevated px-4 py-2 text-sm font-semibold text-sly-ink transition hover:border-sly-accent hover:bg-sly-accent hover:text-white"
        >
          <.icon name="hero-chevron-left-mini" class="size-5 shrink-0" /> Prev
        </button>
        <div class="min-w-0 flex-1" />
        <button
          type="button"
          id="next-btn"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-sly-elevated px-4 py-2 text-sm font-semibold text-sly-ink transition hover:border-sly-accent hover:bg-sly-accent hover:text-white"
        >
          Next <.icon name="hero-chevron-right-mini" class="size-5 shrink-0" />
        </button>
      </div>
    </div>
    </div>
  </div>
</div>
